{
  "name": "xapi-to",
  "version": "0.1.8",
  "description": "Agent-friendly CLI for xapi - discover and call capabilities and APIs",
  "type": "module",
  "bin": {
    "xapi": "src/index.ts"
  },
  "files": [
    "src",
    "!src/tests",
    "README.md"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "XAPI_ACTION_HOST=localhost:3003 bun run src/index.ts",
    "test": "bun test src/tests"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
